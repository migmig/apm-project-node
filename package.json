{
  "name": "apm-project-node",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "start": "./scripts/run-bun-server.sh",
    "start:node": "node src/server.js",
    "dev:client": "vite --config client/vite.config.js",
    "dev:server": "./scripts/run-bun-server.sh --watch",
    "dev:server:node": "node --watch src/server.js",
    "build": "vite build --config client/vite.config.js",
    "preview": "vite preview --config client/vite.config.js"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@vitejs/plugin-react": "^5.0.0",
    "tailwindcss": "^4.1.11",
    "vite": "^7.1.3"
  }
}
